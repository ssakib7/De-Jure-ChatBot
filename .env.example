# Facebook Page Access Token (Meta dashboard -> Messenger API Setup -> Generate access tokens)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# Meta App Secret (App Settings -> Basic -> App Secret). Used to verify webhook signatures.
APP_SECRET=your_app_secret_here


# Any random string you choose. Paste the SAME value into the Meta webhook "Verify token" field.
VERIFY_TOKEN=choose_any_random_string

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Admin panel (served at the root, e.g. http://localhost:3100) for editing the knowledge base ---
# Login credentials for the single admin user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password
# Secret used to sign the admin session cookie. Use a long random string, e.g.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=choose_a_long_random_string

# --- Lead capture (optional) ---
# When the bot detects buying/contact intent it collects the customer's name + phone,
# then saves to a Google Sheet and pings your team's Telegram chat. Configure either
# or both; leave blank to disable that sink. Lead capture turns on if at least one is set.
#
# Fallback: even without detected intent, the bot asks for contact info once the customer
# has sent this many messages in a conversation. Defaults to 3 if unset.
LEAD_MSG_THRESHOLD=3
#
# Re-engagement: if a customer goes quiet mid-chat, send ONE follow-up nudge after this many
# minutes of silence. Defaults to 120 (2h). Set 0 to disable. Keep under 1440 (24h) — Meta only
# allows a plain text reply inside the 24-hour messaging window.
FOLLOWUP_DELAY_MINUTES=120
#
# Google Sheet via an Apps Script web app (Deploy -> Web app -> "Anyone"). Paste the /exec URL:
GOOGLE_SHEET_WEBAPP_URL=
# Optional shared secret checked by the Apps Script (set the same value in the script):
SHEET_SHARED_TOKEN=
# Telegram notification: create a bot via @BotFather for the token, then get the target
# chat id (e.g. message the bot and read it from https://api.telegram.org/bot<TOKEN>/getUpdates):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: include a one-click link to the customer's Business Suite inbox conversation on
# each lead. Read both ids from your inbox URL:
#   https://business.facebook.com/latest/inbox/all/?business_id=<FB_BUSINESS_ID>&asset_id=<FB_PAGE_ID>
# Leave blank to omit the link.
FB_BUSINESS_ID=
FB_PAGE_ID=

# --- Human-feel reply pacing ---
# The bot keeps the typing bubble up for a random pause in this range (seconds) before each
# reply, so it doesn't answer instantly. Gemini's own latency counts toward the pause.
# Defaults to 5–10s. Set both to 0 for instant replies.
REPLY_MIN_SECONDS=5
REPLY_MAX_SECONDS=10

# Local port for the webhook server
PORT=3000

# --- Persistence ---
# Persistent memory. true (default) = remember conversations + captured customers across
# restarts, and skip the lead ask for anyone already captured. Set to false to PAUSE memory
# during development: nothing is loaded or saved, and no customer is recalled, so the lead
# flow runs fresh on every conversation (handy when testing repeatedly from one account).
MEMORY_ENABLED=true
# Folder for the on-disk memory file (bot.db.json): conversation state, pending follow-ups,
# and the roster of captured customers. Defaults to ./data. In Docker this is a mounted
# volume (see docker-compose.yml) so memory survives redeploys.
DATA_DIR=./data

# --- Traefik / TLS (used by docker-compose.yml) ---
# Public domain that points (DNS A record) at this server; Meta webhook URL.
BOT_DOMAIN=bot.dejureacademy.net
# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=admin@dejureacademy.com
